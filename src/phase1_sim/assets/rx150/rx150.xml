<mujoco>
    <compiler angle="radian" coordinate="local"/>
    <option gravity="0 0 -9.81" timestep="0.002"/>
    <worldbody>
        <light pos="0 1 1" dir="0 -1 -1" diffuse="1 1 1"/>
        <geom type="plane" size="1 1 0.1" rgba="0.9 0.9 0.9 1"/>
        <body name="base" pos="0 0 0.1">
            <geom type="cylinder" size="0.1 0.1" rgba="0.2 0.2 0.2 1"/>
            <body name="link1" pos="0 0 0.1">
                <joint name="waist" type="hinge" axis="0 0 1" range="-3.14 3.14"/>
                <geom type="box" size="0.05 0.05 0.1" pos="0 0 0.1"/>
                <body name="link2" pos="0 0 0.2">
                    <joint name="shoulder" type="hinge" axis="0 1 0" range="-1.57 1.57"/>
                    <geom type="box" size="0.05 0.05 0.1" pos="0 0 0.1"/>
                    <body name="link3" pos="0 0 0.2">
                        <joint name="elbow" type="hinge" axis="0 1 0" range="-1.57 1.57"/>
                        <geom type="box" size="0.05 0.05 0.1" pos="0 0 0.1"/>
                        <body name="link4" pos="0 0 0.2">
                            <joint name="wrist_angle" type="hinge" axis="0 1 0" range="-1.57 1.57"/>
                            <geom type="box" size="0.03 0.03 0.05" pos="0 0 0.05"/>
                            <body name="link5" pos="0 0 0.1">
                                <joint name="wrist_rotate" type="hinge" axis="0 0 1" range="-3.14 3.14"/>
                                <geom type="box" size="0.02 0.02 0.02" pos="0 0 0"/>
                                <site name="eef_site" pos="0 0 0.02"/>
                                <!-- Placeholder gripper -->
                                <body name="left_finger" pos="-0.02 0 0.02">
                                    <joint name="left_finger" type="slide" axis="1 0 0" range="0 0.03"/>
                                    <geom type="box" size="0.01 0.01 0.03" pos="0 0 0.03"/>
                                </body>
                                <body name="right_finger" pos="0.02 0 0.02">
                                    <joint name="right_finger" type="slide" axis="-1 0 0" range="0 0.03"/>
                                    <geom type="box" size="0.01 0.01 0.03" pos="0 0 0.03"/>
                                </body>
                            </body>
                        </body>
                    </body>
                </body>
            </body>
        </body>
        
        <!-- Target object -->
        <body name="target" pos="0.3 0 0.1">
            <freejoint/>
            <geom type="box" size="0.02 0.02 0.02" rgba="1 0 0 1" name="target_geom"/>
        </body>
    </worldbody>
    <actuator>
        <motor joint="waist" ctrlrange="-1 1" gear="50"/>
        <motor joint="shoulder" ctrlrange="-1 1" gear="50"/>
        <motor joint="elbow" ctrlrange="-1 1" gear="50"/>
        <motor joint="wrist_angle" ctrlrange="-1 1" gear="20"/>
        <motor joint="wrist_rotate" ctrlrange="-1 1" gear="20"/>
        <position joint="left_finger" ctrlrange="0 0.03" kp="100"/>
        <position joint="right_finger" ctrlrange="0 0.03" kp="100"/>
    </actuator>
</mujoco>
